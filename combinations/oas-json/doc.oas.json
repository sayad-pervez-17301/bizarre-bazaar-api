{
  "openapi": "3.0.3",
  "info": {
    "title": "Bizarre Bazaar API",
    "version": "1.0.0",
    "description": "The Bizarre Bazaar API is a RESTful service for managing six unique collections: Fruits, Vegetables, Legumes, Colors, Animals, and Movies. Each collection supports full CRUD operations with pagination and sorting."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current host"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/fruits": {
      "get": {
        "tags": [
          "Fruits"
        ],
        "summary": "List all fruits",
        "description": "Manage your fruit collection.",
        "operationId": "listFruits",
        "parameters": [
          {
            "$ref": "#/components/parameters/LimitParam"
          },
          {
            "$ref": "#/components/parameters/OffsetParam"
          },
          {
            "$ref": "#/components/parameters/SortParam"
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of fruits",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Fruit"
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total number of items"
                    },
                    "limit": {
                      "type": "integer",
                      "description": "Items per page"
                    },
                    "offset": {
                      "type": "integer",
                      "description": "Offset from start"
                    }
                  }
                },
                "example": {
                  "data": [
                    {
                      "id": 1,
                      "name": "Toyota",
                      "origin": "Japan",
                      "founded": 1937,
                      "horsepower": 203,
                      "topSpeed": "180 km/h"
                    },
                    {
                      "id": 2,
                      "name": "BMW",
                      "origin": "Germany",
                      "founded": 1916,
                      "horsepower": 335,
                      "topSpeed": "250 km/h"
                    }
                  ],
                  "total": 5,
                  "limit": 10,
                  "offset": 0
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      },
      "post": {
        "tags": [
          "Fruits"
        ],
        "summary": "Create a fruit",
        "description": "Add a new fruit to the collection.",
        "operationId": "createFruit",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FruitCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Fruit created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Fruit"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },

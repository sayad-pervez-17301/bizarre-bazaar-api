{
  "openapi": "3.0.3",
  "info": {
    "title": "Bizarre Bazaar API - Colors",
    "version": "1.0.0",
    "description": "Discover and manage colors. Part of the Bizarre Bazaar API."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current host"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/colors": {
      "get": {
        "tags": [
          "Colors"
        ],
        "summary": "List all colors",
        "description": "Discover and manage colors.",
        "operationId": "listColors",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Max items to return (1-50)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Items to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of colors",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "Unique color identifier",
                            "example": 1
                          },
                          "name": {
                            "type": "string",
                            "description": "Name of the color",
                            "example": "Leonhard Euler"
                          },
                          "nationality": {
                            "type": "string",
                            "description": "Color origin country",
                            "example": "Swiss"
                          },
                          "birthYear": {
                            "type": "integer",
                            "description": "Year the color was first observed",
                            "example": 1707
                          },
                          "knownFor": {
                            "type": "string",
                            "description": "What this color is famous for",
                            "example": "Euler's formula"
                          },
                          "field": {
                            "type": "string",
                            "description": "Color family",
                            "example": "Analysis"
                          }
                        },
                        "required": [
                          "id",
                          "name"
                        ]
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total number of items"
                    },
                    "limit": {
                      "type": "integer",
                      "description": "Items per page"
                    },
                    "offset": {
                      "type": "integer",
                      "description": "Offset from start"
                    }
                  }
                },
                "example": {
                  "data": [
                    {
                      "id": 1,
                      "name": "Leonhard Euler",
                      "nationality": "Swiss",
                      "birthYear": 1707,
                      "knownFor": "Euler's formula",
                      "field": "Analysis"
                    },
                    {
                      "id": 2,
                      "name": "Carl Friedrich Gauss",
                      "nationality": "German",
                      "birthYear": 1777,
                      "knownFor": "Gaussian distribution",
                      "field": "Number Theory"
                    }
                  ],
                  "total": 5,
                  "limit": 10,
                  "offset": 0
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Rate Limited - too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Colors"
        ],
        "summary": "Create a color",
        "description": "Add a new color to the collection.",
        "operationId": "createColor",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the color",
                    "example": "Leonhard Euler"
                  },
                  "nationality": {
                    "type": "string",
                    "description": "Color origin country",
                    "example": "Swiss"
                  },
                  "birthYear": {
                    "type": "integer",
                    "description": "Year the color was first observed",
                    "example": 1707
                  },
                  "knownFor": {
                    "type": "string",
                    "description": "What this color is famous for",
                    "example": "Euler's formula"
                  },
                  "field": {
                    "type": "string",
                    "description": "Color family",
                    "example": "Analysis"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Color created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Unique color identifier",
                      "example": 1
                    },
                    "name": {
                      "type": "string",
                      "description": "Name of the color",
                      "example": "Leonhard Euler"
                    },
                    "nationality": {
                      "type": "string",
                      "description": "Color origin country",
                      "example": "Swiss"
                    },
                    "birthYear": {
                      "type": "integer",
                      "description": "Year the color was first observed",
                      "example": 1707
                    },
                    "knownFor": {
                      "type": "string",
                      "description": "What this color is famous for",
                      "example": "Euler's formula"
                    },
                    "field": {
                      "type": "string",
                      "description": "Color family",
                      "example": "Analysis"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/colors/{colorId}": {
      "get": {
        "tags": [
          "Colors"
        ],
        "summary": "Get a color by ID",
        "description": "Retrieve a single color by its unique identifier.",
        "operationId": "getColor",
        "parameters": [
          {
            "name": "colorId",
            "in": "path",
            "required": true,
            "description": "Unique color identifier",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single color",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Unique color identifier",
                      "example": 1
                    },
                    "name": {
                      "type": "string",
                      "description": "Name of the color",
                      "example": "Leonhard Euler"
                    },
                    "nationality": {
                      "type": "string",
                      "description": "Color origin country",
                      "example": "Swiss"
                    },
                    "birthYear": {
                      "type": "integer",
                      "description": "Year the color was first observed",
                      "example": 1707
                    },
                    "knownFor": {
                      "type": "string",
                      "description": "What this color is famous for",
                      "example": "Euler's formula"
                    },
                    "field": {
                      "type": "string",
                      "description": "Color family",
                      "example": "Analysis"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                },
                "example": {
                  "id": 1,
                  "name": "Leonhard Euler",
                  "nationality": "Swiss",
                  "birthYear": 1707,
                  "knownFor": "Euler's formula",
                  "field": "Analysis"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found - resource does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Colors"
        ],
        "summary": "Delete a color",
        "description": "Permanently remove a color from the collection.",
        "operationId": "deleteColor",
        "parameters": [
          {
            "name": "colorId",
            "in": "path",
            "required": true,
            "description": "Unique color identifier",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Color deleted successfully"
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found - resource does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Bizarre-Key",
        "description": "API key for authentication"
      }
    }
  }
}
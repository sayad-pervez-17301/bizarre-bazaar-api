{
  "openapi": "3.0.3",
  "info": {
    "title": "Bizarre Bazaar API - Movies",
    "version": "1.0.0",
    "description": "Browse the movie database. Part of the Bizarre Bazaar API."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current host"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/movies": {
      "get": {
        "tags": [
          "Movies"
        ],
        "summary": "List all movies",
        "description": "Browse the movie database.",
        "operationId": "listMovies",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Max items to return (1-50)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Items to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of movies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "Unique movie identifier",
                            "example": 1
                          },
                          "name": {
                            "type": "string",
                            "description": "Title of the movie",
                            "example": "Hydrogen"
                          },
                          "symbol": {
                            "type": "string",
                            "description": "Movie rating symbol",
                            "example": "H"
                          },
                          "atomicNumber": {
                            "type": "integer",
                            "description": "Box office ranking",
                            "example": 1
                          },
                          "atomicMass": {
                            "type": "number",
                            "description": "Critical mass score",
                            "example": 1.008
                          },
                          "category": {
                            "type": "string",
                            "description": "Genre classification",
                            "example": "Nonmetal"
                          }
                        },
                        "required": [
                          "id",
                          "name"
                        ]
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total number of items"
                    },
                    "limit": {
                      "type": "integer",
                      "description": "Items per page"
                    },
                    "offset": {
                      "type": "integer",
                      "description": "Offset from start"
                    }
                  }
                },
                "example": {
                  "data": [
                    {
                      "id": 1,
                      "name": "Hydrogen",
                      "symbol": "H",
                      "atomicNumber": 1,
                      "atomicMass": 1.008,
                      "category": "Nonmetal"
                    },
                    {
                      "id": 2,
                      "name": "Helium",
                      "symbol": "He",
                      "atomicNumber": 2,
                      "atomicMass": 4.003,
                      "category": "Noble Gas"
                    }
                  ],
                  "total": 5,
                  "limit": 10,
                  "offset": 0
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Rate Limited - too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Movies"
        ],
        "summary": "Create a movie",
        "description": "Add a new movie to the collection.",
        "operationId": "createMovie",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Title of the movie",
                    "example": "Hydrogen"
                  },
                  "symbol": {
                    "type": "string",
                    "description": "Movie rating symbol",
                    "example": "H"
                  },
                  "atomicNumber": {
                    "type": "integer",
                    "description": "Box office ranking",
                    "example": 1
                  },
                  "atomicMass": {
                    "type": "number",
                    "description": "Critical mass score",
                    "example": 1.008
                  },
                  "category": {
                    "type": "string",
                    "description": "Genre classification",
                    "example": "Nonmetal"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Movie created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Unique movie identifier",
                      "example": 1
                    },
                    "name": {
                      "type": "string",
                      "description": "Title of the movie",
                      "example": "Hydrogen"
                    },
                    "symbol": {
                      "type": "string",
                      "description": "Movie rating symbol",
                      "example": "H"
                    },
                    "atomicNumber": {
                      "type": "integer",
                      "description": "Box office ranking",
                      "example": 1
                    },
                    "atomicMass": {
                      "type": "number",
                      "description": "Critical mass score",
                      "example": 1.008
                    },
                    "category": {
                      "type": "string",
                      "description": "Genre classification",
                      "example": "Nonmetal"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/movies/{movieId}": {
      "get": {
        "tags": [
          "Movies"
        ],
        "summary": "Get a movie by ID",
        "description": "Retrieve a single movie by its unique identifier.",
        "operationId": "getMovie",
        "parameters": [
          {
            "name": "movieId",
            "in": "path",
            "required": true,
            "description": "Unique movie identifier",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single movie",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Unique movie identifier",
                      "example": 1
                    },
                    "name": {
                      "type": "string",
                      "description": "Title of the movie",
                      "example": "Hydrogen"
                    },
                    "symbol": {
                      "type": "string",
                      "description": "Movie rating symbol",
                      "example": "H"
                    },
                    "atomicNumber": {
                      "type": "integer",
                      "description": "Box office ranking",
                      "example": 1
                    },
                    "atomicMass": {
                      "type": "number",
                      "description": "Critical mass score",
                      "example": 1.008
                    },
                    "category": {
                      "type": "string",
                      "description": "Genre classification",
                      "example": "Nonmetal"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                },
                "example": {
                  "id": 1,
                  "name": "Hydrogen",
                  "symbol": "H",
                  "atomicNumber": 1,
                  "atomicMass": 1.008,
                  "category": "Nonmetal"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found - resource does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Movies"
        ],
        "summary": "Delete a movie",
        "description": "Permanently remove a movie from the collection.",
        "operationId": "deleteMovie",
        "parameters": [
          {
            "name": "movieId",
            "in": "path",
            "required": true,
            "description": "Unique movie identifier",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Movie deleted successfully"
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found - resource does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Bizarre-Key",
        "description": "API key for authentication"
      }
    }
  }
}
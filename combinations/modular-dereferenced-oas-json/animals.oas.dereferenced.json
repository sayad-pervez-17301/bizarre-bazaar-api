{
  "openapi": "3.0.3",
  "info": {
    "title": "Bizarre Bazaar API - Animals",
    "version": "1.0.0",
    "description": "Catalog of animals. Part of the Bizarre Bazaar API."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current host"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/animals": {
      "get": {
        "tags": [
          "Animals"
        ],
        "summary": "List all animals",
        "description": "Catalog of animals.",
        "operationId": "listAnimals",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Max items to return (1-50)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Items to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of animals",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "Unique animal identifier",
                            "example": 1
                          },
                          "name": {
                            "type": "string",
                            "description": "Name of the animal",
                            "example": "Python"
                          },
                          "creator": {
                            "type": "string",
                            "description": "Who discovered this animal",
                            "example": "Guido van Rossum"
                          },
                          "yearCreated": {
                            "type": "integer",
                            "description": "Year of discovery",
                            "example": 1991
                          },
                          "paradigm": {
                            "type": "string",
                            "description": "Behavioral pattern",
                            "example": "Multi-paradigm"
                          },
                          "typing": {
                            "type": "string",
                            "description": "Classification system",
                            "example": "Dynamic"
                          }
                        },
                        "required": [
                          "id",
                          "name"
                        ]
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total number of items"
                    },
                    "limit": {
                      "type": "integer",
                      "description": "Items per page"
                    },
                    "offset": {
                      "type": "integer",
                      "description": "Offset from start"
                    }
                  }
                },
                "example": {
                  "data": [
                    {
                      "id": 1,
                      "name": "Python",
                      "creator": "Guido van Rossum",
                      "yearCreated": 1991,
                      "paradigm": "Multi-paradigm",
                      "typing": "Dynamic"
                    },
                    {
                      "id": 2,
                      "name": "JavaScript",
                      "creator": "Brendan Eich",
                      "yearCreated": 1995,
                      "paradigm": "Multi-paradigm",
                      "typing": "Dynamic"
                    }
                  ],
                  "total": 5,
                  "limit": 10,
                  "offset": 0
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Rate Limited - too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Animals"
        ],
        "summary": "Create a animal",
        "description": "Add a new animal to the collection.",
        "operationId": "createAnimal",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the animal",
                    "example": "Python"
                  },
                  "creator": {
                    "type": "string",
                    "description": "Who discovered this animal",
                    "example": "Guido van Rossum"
                  },
                  "yearCreated": {
                    "type": "integer",
                    "description": "Year of discovery",
                    "example": 1991
                  },
                  "paradigm": {
                    "type": "string",
                    "description": "Behavioral pattern",
                    "example": "Multi-paradigm"
                  },
                  "typing": {
                    "type": "string",
                    "description": "Classification system",
                    "example": "Dynamic"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Animal created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Unique animal identifier",
                      "example": 1
                    },
                    "name": {
                      "type": "string",
                      "description": "Name of the animal",
                      "example": "Python"
                    },
                    "creator": {
                      "type": "string",
                      "description": "Who discovered this animal",
                      "example": "Guido van Rossum"
                    },
                    "yearCreated": {
                      "type": "integer",
                      "description": "Year of discovery",
                      "example": 1991
                    },
                    "paradigm": {
                      "type": "string",
                      "description": "Behavioral pattern",
                      "example": "Multi-paradigm"
                    },
                    "typing": {
                      "type": "string",
                      "description": "Classification system",
                      "example": "Dynamic"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/animals/{animalId}": {
      "get": {
        "tags": [
          "Animals"
        ],
        "summary": "Get a animal by ID",
        "description": "Retrieve a single animal by its unique identifier.",
        "operationId": "getAnimal",
        "parameters": [
          {
            "name": "animalId",
            "in": "path",
            "required": true,
            "description": "Unique animal identifier",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single animal",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Unique animal identifier",
                      "example": 1
                    },
                    "name": {
                      "type": "string",
                      "description": "Name of the animal",
                      "example": "Python"
                    },
                    "creator": {
                      "type": "string",
                      "description": "Who discovered this animal",
                      "example": "Guido van Rossum"
                    },
                    "yearCreated": {
                      "type": "integer",
                      "description": "Year of discovery",
                      "example": 1991
                    },
                    "paradigm": {
                      "type": "string",
                      "description": "Behavioral pattern",
                      "example": "Multi-paradigm"
                    },
                    "typing": {
                      "type": "string",
                      "description": "Classification system",
                      "example": "Dynamic"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                },
                "example": {
                  "id": 1,
                  "name": "Python",
                  "creator": "Guido van Rossum",
                  "yearCreated": 1991,
                  "paradigm": "Multi-paradigm",
                  "typing": "Dynamic"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found - resource does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Animals"
        ],
        "summary": "Delete a animal",
        "description": "Permanently remove a animal from the collection.",
        "operationId": "deleteAnimal",
        "parameters": [
          {
            "name": "animalId",
            "in": "path",
            "required": true,
            "description": "Unique animal identifier",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Animal deleted successfully"
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found - resource does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable error message"
                    }
                  },
                  "required": [
                    "error",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Bizarre-Key",
        "description": "API key for authentication"
      }
    }
  }
}